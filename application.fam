App(
    appid="mp3_player",
    name="MP3 Player",
    apptype=FlipperAppType.EXTERNAL,
    entry_point="mp3_main",
    requires=["gui", "storage"],
    stack_size=8 * 1024,
    fap_icon="music_icon.png",
    targets=["f7"],
    fap_category="Media",
    fap_author="coolshrimp",
    fap_weburl="https://github.com/coolshrimp/flipperzero-mp3-player",
    fap_version="3.5",
    fap_description="Plays any MP3 bitrate through the internal speaker or an external MAX98357A I2S amplifier.",
)
